# Target environment — swap this when running against dev, staging, or prod.
BASE_URL=https://www.saucedemo.com

# Credentials — in a real project these would live in a secrets manager.
# Here they're the publicly-published SauceDemo demo credentials.
STANDARD_USER=standard_user
LOCKED_USER=locked_out_user
PROBLEM_USER=problem_user
PERF_USER=performance_glitch_user
VISUAL_USER=visual_user
USER_PASSWORD=secret_sauce

# Logging — set to `silent` in CI to reduce noise, leave unset for local debugging.
# LOG_LEVEL=silent
